SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0,web
DJANGO_SETTINGS_MODULE=core.settings.dev

# PostgreSQL
POSTGRES_DB=your-pg-name
POSTGRES_USER=your-pg-user
POSTGRES_PASSWORD=your-pg-password
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Redis
REDIS_URL=redis://redis:6379/0

# JWT
JWT_ACCESS_LIFETIME_MINUTES=60
JWT_REFRESH_LIFETIME_DAYS=7

# OTP
OTP_TTL_SECONDS=300
OTP_MAX_REQUESTS_PER_EMAIL=3
OTP_EMAIL_WINDOW_SECONDS=600
OTP_MAX_REQUESTS_PER_IP=10
OTP_IP_WINDOW_SECONDS=3600
OTP_MAX_FAILED_ATTEMPTS=5
OTP_LOCKOUT_WINDOW_SECONDS=900

# Rate limiting (global)
GLOBAL_RATE_LIMIT_PER_IP=100
GLOBAL_RATE_LIMIT_WINDOW_SECONDS=60

# Logging
LOG_LEVEL=INFO
